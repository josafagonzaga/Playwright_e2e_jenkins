{
  "name": "playwright_testautomationpractice",
  "version": "1.0.0",
  "description": "Projeto de automação de testes E2E com Playwright utilizando o site Test Automation Practice. O objetivo é praticar mapeamento de elementos, criação de cenários automatizados, validações funcionais, organização de testes, reutilização de código e preparação para execução em pipeline CI/CD.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:changed": "node scripts/run-impacted-tests.mjs",
    "test:smoke": "playwright test --grep @smoke",
    "test:content": "playwright test --grep @content",
    "test:links": "playwright test --grep @links",
    "test:navigation": "playwright test --grep @navigation",
    "test:footer": "playwright test --grep @footer",
    "test:mobile": "playwright test --grep @mobile",
    "test:search": "playwright test --grep @search",
    "test:quem-somos": "playwright test --grep @quem-somos",
    "test:trilha-de-estudos": "playwright test --grep @trilha-de-estudos",
    "test:parcerias": "playwright test --grep @parcerias",
    "test:sites-para-praticar": "playwright test --grep @sites-para-praticar",
    "test:ctfl": "playwright test --grep \"@ctfl(\\s|$)\"",
    "test:ctfl-at": "playwright test --grep @ctfl-at",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "quality": "npm run format:check && npm run lint && npm run typecheck",
    "ci": "npm run quality && npm test",
    "ci:changed": "npm run quality && npm run test:changed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josafagonzaga/Playwright_testautomationpractice.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/josafagonzaga/Playwright_testautomationpractice/issues"
  },
  "homepage": "https://github.com/josafagonzaga/Playwright_testautomationpractice#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "eslint": "^10.3.0",
    "eslint-plugin-playwright": "^2.10.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
